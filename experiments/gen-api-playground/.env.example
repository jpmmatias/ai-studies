# Copy to .env and fill with real secrets (never commit .env).

# Official OpenAI or any client that forwards this header as Bearer
OPENAI_API_KEY=

# OpenRouter: https://openrouter.ai/ — single key for many models
OPENROUTER_API_KEY=

# Optional: override when Ollama runs elsewhere
# OLLAMA_HOST=http://127.0.0.1:11434
